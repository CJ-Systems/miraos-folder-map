#!/usr/bin/env python3
"""Run folder-map straight from a clone, without installing it.

This is a thin shim: it puts the bundled ``dna/`` source dir on the import path
and hands off to the real CLI in ``folder_map.cli``. Once the package is
installed (``pipx install .``), the ``folder-map`` command on your PATH runs the
same ``main()`` directly and this file isn't needed.
"""

import os
import sys

_HERE = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, os.path.join(_HERE, "dna"))

from folder_map.cli import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
